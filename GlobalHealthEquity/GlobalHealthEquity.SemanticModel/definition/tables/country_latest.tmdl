table country_latest
	lineageTag: 311c6f20-8d44-43bd-afcb-ae584f7b4bdf

	measure 'Avg Mortality 2023' = AVERAGE(country_latest[under5_mortality_per_1000])
		formatString: 0.0
		lineageTag: d813323c-9a3f-4379-acac-b3b657cc3003

	measure 'Countries 2023' = DISTINCTCOUNT(country_latest[country])
		formatString: #,0
		lineageTag: aaf37018-6920-402b-845a-4f8fcaabeda7

	measure 'GDP per Capita 2023' = AVERAGE(country_latest[gdp_per_capita_usd])
		formatString: #,0
		lineageTag: c469082c-9f8d-490b-ba61-082b46567e65

	measure 'Health Spend per Capita 2023' = AVERAGE(country_latest[health_exp_per_capita_usd])
		formatString: #,0
		lineageTag: f758caba-5304-4e89-a17f-85a86e06d36f

	column iso3c
		dataType: string
		lineageTag: c6ce1989-ae8b-485a-9571-647be3e691d0
		summarizeBy: none
		sourceColumn: iso3c

		annotation SummarizationSetBy = Automatic

	column country
		dataType: string
		dataCategory: Country
		lineageTag: effb0950-fbd0-440b-98e7-1de94a3d1b2b
		summarizeBy: none
		sourceColumn: country

		annotation SummarizationSetBy = Automatic

