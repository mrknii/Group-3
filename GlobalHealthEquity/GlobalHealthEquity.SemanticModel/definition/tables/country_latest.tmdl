		sourceColumn: income_group

		annotation SummarizationSetBy = Automatic

	column latest_year
		dataType: int64
		formatString: 0
		lineageTag: 20694236-0496-444e-8511-9ca28ead38b3
		summarizeBy: none
		sourceColumn: latest_year

		annotation SummarizationSetBy = Automatic

	column gdp_per_capita_usd
		dataType: double
		lineageTag: f8385315-ed53-454b-8f87-21e9b584a3e8
		summarizeBy: none
		sourceColumn: gdp_per_capita_usd

		annotation SummarizationSetBy = Automatic

	column health_exp_pct_gdp
