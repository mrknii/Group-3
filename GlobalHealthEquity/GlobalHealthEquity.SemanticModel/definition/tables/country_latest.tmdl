	column under5_mortality_per_1000
		dataType: double
		lineageTag: 1a0104fb-c796-4cba-a251-40dca7589879
		summarizeBy: none
		sourceColumn: under5_mortality_per_1000

		annotation SummarizationSetBy = Automatic

	column 'Mortality Band' = SWITCH(TRUE(), [under5_mortality_per_1000] < 10, "0-10", [under5_mortality_per_1000] < 25, "10-25", [under5_mortality_per_1000] < 50, "25-50", [under5_mortality_per_1000] < 75, "50-75", "75+")
		dataType: string
		lineageTag: 8f64620f-1238-4009-84ff-85a04efb9948
		summarizeBy: none
		sortByColumn: 'Mortality Band Order'

		annotation SummarizationSetBy = Automatic

	column 'Mortality Band Order' = SWITCH(TRUE(), [under5_mortality_per_1000] < 10, 1, [under5_mortality_per_1000] < 25, 2, [under5_mortality_per_1000] < 50, 3, [under5_mortality_per_1000] < 75, 4, 5)
		dataType: int64
		formatString: 0
		isHidden
		lineageTag: 715cb329-662b-430a-8573-01c7794a5a28
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition country_latest = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(DataPath & "\country_latest.csv"), [Delimiter=",", Columns=9, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"iso3c", type text}, {"country", type text}, {"region", type text}, {"income_group", type text}, {"latest_year", Int64.Type}, {"gdp_per_capita_usd", type number}, {"health_exp_pct_gdp", type number}, {"health_exp_per_capita_usd", type number}, {"under5_mortality_per_1000", type number}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Table
